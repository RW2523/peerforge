# ── PeerForge API — environment template ────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).

# ── Database (Supabase Postgres or local) ───────────────────────────────────
# Supabase: Project Settings → Database → Connection string (URI), use the
# pooled connection (port 6543) for serverless/free hosts.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/peerforge_local

# ── Auth (Supabase) ─────────────────────────────────────────────────────────
# REQUIRE_AUTH=false bypasses auth for local dev. Set true in production.
REQUIRE_AUTH=true
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=<project-ref>
# Project Settings → API → JWT secret (used to verify access tokens)
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Institutional layer & billing (see docs/INSTITUTIONAL.md) ───────────────
# Default plan for workspaces with no explicit plan (workspaces.plan overrides
# per-workspace): community | professional | institution.
# Gates departments/invites/SSO + session/material quotas; unknown values fail
# closed to community. Production ships on the free tier so the paywall is
# active by default — raise a workspace's plan via the owner /billing switch or
# Stripe. (Local dev defaults to institution in code so it's never blocked.)
PLAN=community

# Payment (optional). Without these, owner plan-switches apply immediately.
# With them, paid upgrades go through Stripe Checkout and the webhook sets the
# plan. STRIPE_PRICE_IDS maps plan → Stripe price id as JSON.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_IDS={"professional":"price_...","institution":"price_..."}

# ── API server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ── Encryption for account-stored provider keys (REQUIRED) ──────────────────
# Generate once:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Changing this makes previously stored OpenRouter keys undecryptable.
KEY_ENCRYPTION_SECRET=

# ── OpenRouter (optional server fallback key) ───────────────────────────────
# Users bring their own key; this is only a fallback for background tasks.
OPENROUTER_API_KEY=

# ── Background tasks ────────────────────────────────────────────────────────
# Free tier (no worker / no Redis): set CELERY_TASK_ALWAYS_EAGER=true so tasks
# run inline in the API process. With a worker + Redis, leave it false.
CELERY_TASK_ALWAYS_EAGER=false
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Object storage ──────────────────────────────────────────────────────────
# STORAGE_BACKEND=minio (local/Railway MinIO) or s3 (Supabase Storage / R2 / AWS).
STORAGE_BACKEND=minio
# -- MinIO --
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=peerforge-materials
MINIO_SECURE=false
# -- S3 / Supabase Storage (when STORAGE_BACKEND=s3) --
# S3_ENDPOINT_URL=https://<project-ref>.storage.supabase.co/storage/v1/s3
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=peerforge-materials

# ── Research / web-search integrations (optional) ───────────────────────────
SEMANTIC_SCHOLAR_API_KEY=
JINA_API_KEY=
TAVILY_API_KEY=

# ── Certificate signing (Pillar 3 — Readiness Certificate) ──────────────────
# Ed25519 private key (PEM) used to sign Review-Readiness Certificates.
# If unset, a dev key is auto-generated and stored in the signing_keys table.
# In production, supply a managed key here so the DB never holds the secret.
# Generate one with:
#   openssl genpkey -algorithm ed25519 -out cert_key.pem && cat cert_key.pem
# CERT_SIGNING_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
