# PeerForge frontend — production environment (set these in Vercel → Settings → Environment Variables)
# All NEXT_PUBLIC_* values are exposed to the browser by design.

# URL of the deployed FastAPI backend (Railway/Render). No trailing slash.
NEXT_PUBLIC_API_URL=https://your-backend-host.example.com

# Real Supabase auth (login enabled)
NEXT_PUBLIC_AUTH_MODE=production

# Supabase project (publishable key + URL are public-safe)
NEXT_PUBLIC_SUPABASE_URL=https://tpbxkjdpxuhwasiigmsg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_TBqoM2aYi5OPAetoicI37g_4RMRvgOQ
