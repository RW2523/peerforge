# ── PeerForge Web — environment template ────────────────────────────────────
# Copy to `.env.local` and fill in. Real .env.local is gitignored.
# All NEXT_PUBLIC_* vars are exposed to the browser — never put secrets here.

# Backend API base URL (Railway/Render URL in production, localhost in dev)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth mode: "supabase" (production) or "dev" (local bypass)
NEXT_PUBLIC_AUTH_MODE=supabase

# Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Publishable key (sb_publishable_…) — safe for the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
