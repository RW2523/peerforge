{
  "name": "@arinar/contracts",
  "version": "1.0.0",
  "description": "API contracts and shared types for Arinar V2",
  "private": true,
  "main": "src/generated/index.ts",
  "scripts": {
    "generate:types": "node scripts/generate-types.js",
    "validate:openapi": "node scripts/validate-openapi.js",
    "validate:schemas": "node scripts/validate-schemas.js",
    "validate:all": "npm run validate:openapi && npm run validate:schemas",
    "test": "node --test tests/*.test.js",
    "build": "npm run validate:all && npm run generate:types"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "openapi-typescript": "^6.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "contracts",
    "openapi",
    "schemas",
    "types"
  ]
}
