{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://arinar.com/schemas/events/base-event.json",
  "title": "Base Event",
  "description": "Base schema for all debate events",
  "type": "object",
  "required": [
    "event_id",
    "debate_id",
    "event_type",
    "sender_type",
    "created_at"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier"
    },
    "debate_id": {
      "type": "string",
      "format": "uuid",
      "description": "Debate session identifier"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "agent_message",
        "human_message",
        "agent_question",
        "agent_rebuttal",
        "intervention",
        "evidence_request",
        "evidence_response",
        "summary_update",
        "decision_candidate",
        "decision_finalized",
        "pre_turn_nudge",
        "nudge_approved",
        "nudge_rejected",
        "research_request",
        "research_result",
        "research_denied",
        "knowledge_imported",
        "knowledge_rejected",
        "unknown_response",
        "tool_call_request",
        "tool_call_result",
        "tool_call_denied",
        "voice_transcript_partial",
        "voice_transcript_final",
        "voice_tts_started",
        "voice_tts_completed",
        "debate_summary"
      ]
    },
    "sender_type": {
      "type": "string",
      "enum": ["agent", "human", "system"]
    },
    "sender_id": {
      "type": "string",
      "format": "uuid",
      "description": "Sender participant identifier"
    },
    "mentions": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "description": "Mentioned participant IDs"
    },
    "thread_id": {
      "type": "string",
      "format": "uuid",
      "description": "Optional thread identifier for grouped messages"
    },
    "content": {
      "type": "object",
      "description": "Event-specific payload"
    },
    "citation_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id"],
        "properties": {
          "source_id": {
            "type": "string"
          },
          "excerpt": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3,
      "description": "Priority tier: 0=P0 (user intervention), 1=P1 (direct mention), 2=P2 (scheduled), 3=P3 (optional)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Event creation timestamp (UTC ISO-8601)"
    }
  }
}
